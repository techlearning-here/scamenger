# Supabase (required for report-scams and auth)
# Project URL from Supabase dashboard: Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
# Service role key (backend only; keep secret). Prefer this for server-side full access.
SUPABASE_SERVICE_ROLE_KEY=
# Anon key (optional; use if you only need RLS-limited access from backend)
# SUPABASE_ANON_KEY=

# Admin (use UUID for username and UUID for password; set in env)
# ADMIN_USERNAME=11111111-1111-4111-a111-111111111111
# ADMIN_PASSWORD=22222222-2222-4222-a222-222222222222
# ADMIN_SECRET=your-secret-at-least-32-chars
