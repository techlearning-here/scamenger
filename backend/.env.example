# Copy to .env and set values. Do not commit .env.

# -----------------------------------------------------------------------------
# Supabase (required for reports, contact messages, and auth)
# From Supabase dashboard: Project Settings → API
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Anon key (optional; use if backend needs RLS-limited access)
# SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Admin (optional for local dev – defaults in app/core/config.py work)
# Required in production. Use strong values; UUIDs are fine for username/password.
# -----------------------------------------------------------------------------
# ADMIN_USERNAME=11111111-1111-4111-a111-111111111111
# ADMIN_PASSWORD=22222222-2222-4222-a222-222222222222
# ADMIN_SECRET=your-secret-at-least-32-chars

# -----------------------------------------------------------------------------
# Optional: when API is served behind a path prefix (e.g. /api)
# Set ROOT_PATH=api so routes are mounted at /api/reports, /api/z7k2m9, etc.
# Leave unset when running at root (e.g. http://localhost:8000).
# -----------------------------------------------------------------------------
# ROOT_PATH=api
