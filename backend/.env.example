# Copy to .env and set values. Do not commit .env.

# -----------------------------------------------------------------------------
# Supabase (required for reports, contact messages, and auth)
# From Supabase dashboard: Project Settings → API
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Anon key (optional; use if backend needs RLS-limited access)
# SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Admin (required for admin login at /z7k2m9). Set all three.
# Use strong values; UUIDs are fine for username/password.
# ADMIN_SECRET must be at least 32 characters (used for JWT signing).
# -----------------------------------------------------------------------------
# Admin name (login username)
ADMIN_USERNAME=
# Admin password (login password)
ADMIN_PASSWORD=
ADMIN_SECRET=

# -----------------------------------------------------------------------------
# Optional: symmetric encryption for admin login password in transit
# 32-byte key, base64-encoded (e.g. python3 -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())").
# When set: frontend sends password to Next.js API route, which encrypts and sends password_encrypted to backend. Set same value in frontend (Vercel) so the API route can encrypt. Leave unset to send plaintext password.
# -----------------------------------------------------------------------------
# ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Optional: when API is served behind a path prefix (e.g. /api)
# Set ROOT_PATH=api so routes are mounted at /api/reports, /api/z7k2m9, etc.
# Leave unset when running at root (e.g. http://localhost:8000).
# -----------------------------------------------------------------------------
# ROOT_PATH=api

# -----------------------------------------------------------------------------
# Facebook (optional – post approved reports to your Scam Avenger Facebook Page)
# From Meta for Developers: App → Your App → Add Product → Facebook Login;
# then create a Page access token with pages_manage_posts and pages_read_engagement.
# -----------------------------------------------------------------------------
# FACEBOOK_PAGE_ID=
# FACEBOOK_PAGE_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Threads (optional – post approved reports to your Scam Avenger Threads account)
# From Meta for Developers: add Threads API to your app; use Threads user access token.
# THREADS_USER_ID is your Threads/Instagram Business Account user ID (numeric).
# -----------------------------------------------------------------------------
# THREADS_USER_ID=
# THREADS_ACCESS_TOKEN=
