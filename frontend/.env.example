# Google AdSense (optional)
# Get your publisher ID and slot IDs from https://www.google.com/adsense/
# Only set these when you're ready to show ads. Leave unset to run without ads.

# Your AdSense client/publisher ID (e.g. ca-pub-xxxxxxxxxxxxxxxx)
PUBLIC_ADSENSE_CLIENT=

# Ad slot ID for the main placement (below content, above footer). Create an "Display" ad unit in AdSense to get a slot ID.
PUBLIC_ADSENSE_SLOT_MAIN=

# Supabase (optional – for report-scams, auth, and public data)
# Project URL: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Anon key (public; safe to expose in client). Required if frontend talks to Supabase (e.g. auth).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend API for report-scams (required for Submit report and viewing report by slug)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Contact form: mailto recipient (optional; defaults to contact@scamenger.com)
NEXT_PUBLIC_CONTACT_EMAIL=

# Footer social links (optional). Set to full profile URLs; leave unset to use defaults below.
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/profile.php?id=61583635741795
# NEXT_PUBLIC_YOUTUBE_URL=
# NEXT_PUBLIC_X_URL=
# NEXT_PUBLIC_LINKEDIN_URL=
# NEXT_PUBLIC_TELEGRAM_URL=
