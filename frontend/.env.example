# Google Analytics 4 (optional)
# Measurement ID from GA4 Admin → Data streams → Web stream (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google site verification (optional). For AdSense verification: choose "Meta tag" in AdSense, copy the content value, set it here, then deploy and click Verify.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google AdSense (optional)
# Step-by-step guide: see docs/ADSENSE_SETUP.md
# Get your publisher ID and slot IDs from https://www.google.com/adsense/
# Only set these when you're ready to show ads. Leave unset to run without ads.
# Ads are hidden on index pages (/, /tools/, /tools/books/, /stories/). Other pages: 2 ads (top + bottom). Long-form: 3 (top + mid + bottom).

# Your AdSense client/publisher ID (e.g. ca-pub-xxxxxxxxxxxxxxxx)
NEXT_PUBLIC_ADSENSE_CLIENT=

# Ad slot for top placement (below header). Optional; falls back to SLOT_MAIN if unset.
NEXT_PUBLIC_ADSENSE_SLOT_TOP=

# Ad slot for main placement (below content, above footer). Required when using AdSense.
NEXT_PUBLIC_ADSENSE_SLOT_MAIN=

# Ad slot for mid-content on long pages (story/scam guides). Optional; falls back to SLOT_MAIN if unset.
NEXT_PUBLIC_ADSENSE_SLOT_MID=

# Supabase (optional – for report-scams, auth, and public data)
# Project URL: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Anon key (public; safe to expose in client). Required if frontend talks to Supabase (e.g. auth).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (server-only; never expose to client). Required for newsletter unsubscribe (updates DB). Supabase dashboard → Project Settings → API.
# SUPABASE_SERVICE_ROLE_KEY=

# Backend API for report-scams (required for Submit report and viewing report by slug)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: same as backend ENCRYPTION_KEY. Used by API route POST /api/z7k2m9/login to encrypt password before forwarding to backend. Set on Vercel (server-side) and in .env.local for local dev. Must match backend.
# ENCRYPTION_KEY=

# Amazon Associates (optional). If set, book product links will include your affiliate tag.
# Get your tag from Amazon Associates: https://affiliate-program.amazon.com/
# NEXT_PUBLIC_AMAZON_ASSOCIATE_TAG=your-tag-20

# Contact form: mailto recipient (optional; defaults to contact@scamenger.com)
NEXT_PUBLIC_CONTACT_EMAIL=contact@scamenger.com

# Footer social links (optional). Set to full profile URLs; leave unset to use defaults below.
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/profile.php?id=61583635741795
NEXT_PUBLIC_YOUTUBE_URL=https://www.youtube.com/channel/UCGqJUFGpEnWyyN5DahN_9Yw
NEXT_PUBLIC_X_URL=https://x.com/Scamengerx
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/scamenger-avenger-5705603b6
# NEXT_PUBLIC_TELEGRAM_URL=
# NEXT_PUBLIC_INSTAGRAM_URL=
# NEXT_PUBLIC_THREADS_URL=
# NEXT_PUBLIC_TIKTOK_URL=
# NEXT_PUBLIC_REDDIT_URL=
# NEXT_PUBLIC_BLUESKY_URL=
# NEXT_PUBLIC_PINTEREST_URL=
