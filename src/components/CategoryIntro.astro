---
interface Props {
  /** Short summary / purpose of this section */
  intro: string;
  /** "What to do right now" items */
  steps: string[];
}

const { intro, steps } = Astro.props;
---

<section class="category-intro" aria-labelledby="intro-heading">
  <h2 id="intro-heading">Summary & what to do</h2>
  <p class="intro-text">{intro}</p>
  <h3 class="steps-heading">What to do right now</h3>
  <ul class="steps-list">
    {steps.map((step) => <li>{step}</li>)}
  </ul>
</section>

<style>
  .category-intro {
    margin: var(--space-xl) 0;
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: 0 var(--radius) var(--radius) 0;
  }

  .category-intro h2 {
    margin-top: 0;
    margin-bottom: var(--space-md);
    font-size: 1.1rem;
    color: var(--color-text-muted);
  }

  .intro-text {
    margin: 0 0 var(--space-lg);
    font-size: 1rem;
    line-height: 1.6;
  }

  .steps-heading {
    font-size: 1rem;
    margin: 0 0 var(--space-sm);
    color: var(--color-text);
  }

  .steps-list {
    margin: 0;
    padding-left: 1.25rem;
  }

  .steps-list li {
    margin-bottom: var(--space-sm);
    line-height: 1.5;
  }
</style>
