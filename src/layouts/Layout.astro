---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Comma-separated or array of meta keywords (fraud, scam report, etc.). Optional; default includes fraud and related terms. */
  keywords?: string | string[];
  /** Base path for country-specific pages (e.g. "/us"). When set, nav shows category links under this base. */
  base?: string;
  /** Full URL for canonical link and og:url. If not set, uses site + current path. */
  canonical?: string;
  /** Full URL for og:image and twitter:image (e.g. hero image). Recommended 1200x630. */
  image?: string;
  /** Set to true to add noindex (e.g. draft pages). */
  noIndex?: boolean;
}

const { title, description, keywords: keywordsProp, base = '', canonical: canonicalProp, image, noIndex = false } = Astro.props;
const baseUrl = import.meta.env.BASE_URL || '';
const siteRoot = baseUrl.replace(/\/$/, '');
const homeHref = siteRoot ? `${siteRoot}/` : '/';

const siteOrigin = Astro.site ? new URL(Astro.site).origin : '';
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const canonicalUrl = canonicalProp ?? (siteOrigin ? `${siteOrigin}${pathname}${pathname === '/' ? '' : '/'}` : undefined);
const fullTitle = title === 'Scam Avenger' ? 'Scam Avenger – Where to Report Scams, Fraud & Corruption' : `${title} | Scam Avenger`;
const metaDescription = description ?? 'Find where to report scams, fraud, and corruption in the USA. Report to FTC, IC3, CFPB, and official channels.';
const ogImage = image ?? undefined;
const ogImageAlt = 'Report scams, fraud, and corruption – Scam Avenger connects you to official U.S. reporting channels.';

const defaultKeywords = 'report scam, report fraud, consumer fraud, where to report scam, where to report fraud, FTC report fraud, IC3 internet crime, CFPB complaint, identity theft report, government corruption report, report corruption, elder fraud, phishing report, scam reporting USA';
const metaKeywords = keywordsProp == null
  ? defaultKeywords
  : Array.isArray(keywordsProp)
    ? keywordsProp.join(', ')
    : keywordsProp;

const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT as string | undefined;
const adsenseSlotMain = import.meta.env.PUBLIC_ADSENSE_SLOT_MAIN as string | undefined;
const showAdsense = Boolean(adsenseClient && adsenseSlotMain);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <link rel="apple-touch-icon" href={`${baseUrl}favicon.svg`} />
    <meta name="description" content={metaDescription} />
    <meta name="keywords" content={metaKeywords} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Scam Avenger" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:alt" content={ogImageAlt} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}
    <meta property="og:locale" content="en_US" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {ogImage && <meta name="twitter:image:alt" content={ogImageAlt} />}
    {/* JSON-LD WebSite for search engines */}
    {siteOrigin && (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'Scam Avenger',
        url: siteOrigin,
        description: 'Find where to report scams, fraud, and corruption. We connect you to official U.S. channels: FTC ReportFraud, IC3, CFPB, Oversight.gov, and state agencies.',
      })} />
    )}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />
    {showAdsense && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
        crossorigin="anonymous"
      />
    )}
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <nav class="site-nav" aria-label="Main">
          <a href={homeHref}>Home</a>
          <a href="/news/">News</a>
          <a href="/about/">About</a>
        </nav>
      </div>
    </header>
    <main class="main">
      <div class="container">
        <slot />
      </div>
      {showAdsense && (
        <div class="container ad-container">
          <ins
            class="adsbygoogle ad-block"
            data-ad-client={adsenseClient}
            data-ad-slot={adsenseSlotMain}
            data-ad-format="auto"
            data-full-width-responsive="true"
          />
          <script is:inline>
            (function () {
              try {
                (window.adsbygoogle = window.adsbygoogle || []).push({});
              } catch (e) {}
            })();
          </script>
        </div>
      )}
    </main>
    <footer class="site-footer">
      <div class="container">
        <p class="disclaimer">We do not take reports. We only help you find the right official channels to report scams and corruption.</p>
        <p class="copy">&copy; Scam Avenger. Links go to official government and trusted sites. Hero image from <a href="https://www.pexels.com" target="_blank" rel="noopener noreferrer">Pexels</a>.</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    background: var(--gradient-header);
    border-bottom: 3px solid var(--color-accent);
    padding: var(--space-md) 0;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 10%;
    width: 100%;
  }

  .site-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg);
  }

  .site-nav a {
    color: var(--color-header-text);
    font-size: 1rem;
    font-weight: 500;
  }

  .site-nav a:hover {
    color: #a4d4f4;
    text-decoration: none;
  }

  .main {
    padding: var(--space-xl) 0;
    min-height: 50vh;
  }

  .ad-container {
    margin-top: var(--space-xl);
    padding-top: var(--space-xl);
    min-height: 100px;
  }

  .ad-block {
    display: block;
  }

  .site-footer {
    background: var(--gradient-header);
    border-top: 1px solid rgba(255,255,255,0.1);
    padding: var(--space-md) 0;
    margin-top: var(--space-xl);
  }

  .disclaimer {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.9);
    margin-bottom: var(--space-xs);
  }

  .copy {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.8);
    margin: 0;
  }

  .copy a {
    color: #a4d4f4;
  }

  .copy a:hover {
    color: #fff;
  }
</style>
