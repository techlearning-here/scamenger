---
import Layout from '../../layouts/Layout.astro';

const API = 'https://api.rss2json.com/v1/api.json';
const MAX_ITEMS = 45;

/** Multiple official RSS feeds for scam/fraud/consumer protection news */
const NEWS_FEEDS: Array<{ url: string; sourceName: string }> = [
  { url: 'https://www.ftc.gov/feeds/press-release-consumer-protection.xml', sourceName: 'FTC' },
  { url: 'https://www.ftc.gov/feeds/press-release.xml', sourceName: 'FTC' },
  { url: 'https://www.consumer.ftc.gov/blog/gd-rss.xml', sourceName: 'FTC Consumer' },
  { url: 'https://www.ic3.gov/rss/news.xml', sourceName: 'FBI IC3' },
  { url: 'https://www.consumerfinance.gov/about-us/newsroom/feed/', sourceName: 'CFPB' },
];

type NewsItem = { title: string; link: string; pubDate: string; description?: string; source?: string };

/** Fetch one feed via rss2json and return items with source tag */
async function fetchFeed(feed: { url: string; sourceName: string }): Promise<NewsItem[]> {
  try {
    const apiUrl = `${API}?rss_url=${encodeURIComponent(feed.url)}`;
    const res = await fetch(apiUrl, { signal: AbortSignal.timeout(15000) });
    const data = await res.json();
    if (data?.status !== 'ok' || !Array.isArray(data.items)) return [];
    return data.items.map((item: { title?: string; link?: string; pubDate?: string; description?: string }) => ({
      title: item.title || 'Untitled',
      link: item.link || '#',
      pubDate: item.pubDate || '',
      description: item.description || '',
      source: feed.sourceName,
    }));
  } catch {
    return [];
  }
}

/** Fetch all feeds, merge, sort by date (newest first), dedupe by link, limit */
let newsItems: NewsItem[] = [];
try {
  const results = await Promise.all(NEWS_FEEDS.map((f) => fetchFeed(f)));
  const merged = results.flat();
  const seen = new Set<string>();
  const deduped = merged.filter((item) => {
    const key = item.link?.toLowerCase() || item.title;
    if (seen.has(key)) return false;
    seen.add(key);
    return true;
  });
  deduped.sort((a, b) => {
    const tA = new Date(a.pubDate).getTime();
    const tB = new Date(b.pubDate).getTime();
    return Number.isNaN(tB) ? -1 : Number.isNaN(tA) ? 1 : tB - tA;
  });
  newsItems = deduped.slice(0, MAX_ITEMS);
} catch {
  newsItems = [];
}
const siteOrigin = Astro.site ? new URL(Astro.site).origin : '';
const canonicalUrl = siteOrigin ? `${siteOrigin}/news/` : undefined;
---

<Layout
  title="Scam & fraud news"
  description="Latest scam, fraud, and consumer protection news from the FTC and trusted sources."
  keywords="scam news, fraud news, FTC consumer protection, scam alerts, consumer fraud alerts"
  canonical={canonicalUrl}
>
  <header class="news-hero">
    <img
      src="https://images.unsplash.com/photo-1504711434969-e33886168f5c?auto=format&fit=crop&w=1200&q=80"
      alt=""
      width="1200"
      height="280"
      class="news-hero-img"
    />
    <div class="news-hero-overlay">
      <h1 class="news-hero-title">Scam & fraud news</h1>
      <p class="news-hero-tagline">Latest consumer protection and scam alerts.</p>
    </div>
  </header>
  <p class="intro">Recent consumer protection and scam-related news. Use this to stay aware of current threats and enforcement actions.</p>

  {newsItems.length > 0 ? (
    <div id="news-container" class="news-container">
      <ul class="news-list">
        {newsItems.map((item) => {
          const desc = item.description?.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim().slice(0, 220);
          return (
            <li class="news-item">
              <a href={item.link} target="_blank" rel="noopener noreferrer" class="news-title">{item.title}</a>
              <span class="news-meta">
                {item.source && <span class="news-source-tag">{item.source}</span>}
              </span>
              {desc && <p class="news-desc">{desc}{desc.length >= 220 ? '…' : ''}</p>}
            </li>
          );
        })}
      </ul>
    </div>
  ) : (
    <div id="news-container" class="news-container">
      <p class="news-loading" aria-live="polite">Loading news…</p>
    </div>
  )}

  <div id="news-fallback" class="news-fallback" hidden={newsItems.length > 0}>
    <p>News feed is temporarily unavailable. You can still get the latest scam alerts from these sources:</p>
    <ul>
      <li><a href="https://consumer.ftc.gov/consumer-alerts" target="_blank" rel="noopener noreferrer">FTC Consumer Alerts</a></li>
      <li><a href="https://www.ic3.gov/News" target="_blank" rel="noopener noreferrer">FBI IC3 News</a></li>
      <li><a href="https://www.consumerfinance.gov/about-us/newsroom/" target="_blank" rel="noopener noreferrer">CFPB Newsroom</a></li>
    </ul>
  </div>

  <p class="news-source">Feeds: <a href="https://www.ftc.gov/news-events/stay-connected/ftc-rss-feeds" target="_blank" rel="noopener noreferrer">FTC Press Releases</a>, <a href="https://www.consumer.ftc.gov/blog" target="_blank" rel="noopener noreferrer">FTC Consumer Blog</a>, <a href="https://www.ic3.gov/PSA" target="_blank" rel="noopener noreferrer">FBI IC3 News</a>, <a href="https://www.consumerfinance.gov/about-us/newsroom/" target="_blank" rel="noopener noreferrer">CFPB Newsroom</a>.</p>
</Layout>

<script>
  const API = 'https://api.rss2json.com/v1/api.json';
  const MAX_ITEMS = 45;
  const NEWS_FEEDS = [
    { url: 'https://www.ftc.gov/feeds/press-release-consumer-protection.xml', sourceName: 'FTC' },
    { url: 'https://www.ftc.gov/feeds/press-release.xml', sourceName: 'FTC' },
    { url: 'https://www.consumer.ftc.gov/blog/gd-rss.xml', sourceName: 'FTC Consumer' },
    { url: 'https://www.ic3.gov/rss/news.xml', sourceName: 'FBI IC3' },
    { url: 'https://www.consumerfinance.gov/about-us/newsroom/feed/', sourceName: 'CFPB' },
  ];

  const container = document.getElementById('news-container');
  const fallback = document.getElementById('news-fallback');

  function snippet(html) {
    if (!html) return '';
    const plain = html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
    return plain.length > 220 ? plain.slice(0, 220) + '…' : plain;
  }

  function showFallback() {
    if (container) container.hidden = true;
    if (fallback) {
      fallback.hidden = false;
    }
  }

  function renderList(items) {
    if (!container || !items.length) {
      showFallback();
      return;
    }
    const ul = document.createElement('ul');
    ul.className = 'news-list';
    for (const item of items) {
      const li = document.createElement('li');
      li.className = 'news-item';
      const title = document.createElement('a');
      title.href = item.link || '#';
      title.target = '_blank';
      title.rel = 'noopener noreferrer';
      title.className = 'news-title';
      title.textContent = item.title || 'Untitled';
      const meta = document.createElement('span');
      meta.className = 'news-meta';
      if (item.source) {
        const tag = document.createElement('span');
        tag.className = 'news-source-tag';
        tag.textContent = item.source;
        meta.appendChild(tag);
      }
      li.appendChild(title);
      li.appendChild(meta);
      const desc = snippet(item.description);
      if (desc) {
        const p = document.createElement('p');
        p.className = 'news-desc';
        p.textContent = desc;
        li.appendChild(p);
      }
      ul.appendChild(li);
    }
    container.innerHTML = '';
    container.appendChild(ul);
    container.hidden = false;
    if (fallback) fallback.hidden = true;
  }

  async function fetchOneFeed(feed) {
    try {
      const apiUrl = `${API}?rss_url=${encodeURIComponent(feed.url)}`;
      const res = await fetch(apiUrl, { signal: AbortSignal.timeout(15000) });
      const text = await res.text();
      const data = text ? JSON.parse(text) : null;
      if (data?.status !== 'ok' || !Array.isArray(data.items)) return [];
      return data.items.map((item) => ({
        title: item.title || 'Untitled',
        link: item.link || '#',
        pubDate: item.pubDate || '',
        description: item.description || '',
        source: feed.sourceName,
      }));
    } catch {
      return [];
    }
  }

  async function loadNews() {
    if (!container) return;
    try {
      const results = await Promise.all(NEWS_FEEDS.map(fetchOneFeed));
      const merged = results.flat();
      const seen = new Set();
      const deduped = merged.filter((item) => {
        const key = (item.link || item.title || '').toLowerCase();
        if (seen.has(key)) return false;
        seen.add(key);
        return true;
      });
      deduped.sort((a, b) => {
        const tA = new Date(a.pubDate).getTime();
        const tB = new Date(b.pubDate).getTime();
        return (Number.isNaN(tB) ? -1 : Number.isNaN(tA) ? 1 : tB - tA);
      });
      renderList(deduped.slice(0, MAX_ITEMS));
    } catch {
      showFallback();
    }
  }

  if (document.getElementById('news-container')?.querySelector('.news-loading')) {
    loadNews();
  }
</script>

<style>
  .news-hero {
    position: relative;
    margin: 0 calc(-1 * var(--space-lg)) var(--space-xl);
    border-radius: var(--radius);
    overflow: hidden;
    max-width: calc(100% + 2 * var(--space-lg));
  }

  .news-hero-img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
    background: var(--color-border);
  }

  .news-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, transparent 55%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-lg);
  }

  .news-hero-title {
    margin: 0;
    font-size: 1.5rem;
    color: #fff;
    text-shadow: 0 1px 2px rgba(0,0,0,0.5);
  }

  .news-hero-tagline {
    margin: var(--space-xs) 0 0;
    font-size: 0.95rem;
    color: rgba(255,255,255,0.9);
  }

  .intro {
    margin-bottom: var(--space-xl);
    color: var(--color-text-muted);
  }

  .news-container {
    min-height: 120px;
  }

  .news-loading {
    color: var(--color-text-muted);
    padding: var(--space-lg) 0;
  }

  .news-fallback {
    padding: var(--space-xl) 0;
  }

  .news-fallback[hidden] {
    display: none;
  }

  .news-fallback ul {
    margin-top: var(--space-md);
  }

  .news-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .news-item {
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .news-item:last-child {
    border-bottom: none;
  }

  .news-title {
    display: block;
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: var(--space-xs);
  }

  .news-title:hover {
    text-decoration: underline;
  }

  .news-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .news-source-tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    background: rgba(0, 113, 188, 0.1);
    padding: 0.15em 0.5em;
    border-radius: var(--radius);
  }

  .news-desc {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .news-source {
    margin-top: var(--space-2xl);
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }
</style>
