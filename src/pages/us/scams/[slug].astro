---
import Layout from '../../../layouts/Layout.astro';
import CategoryIntro from '../../../components/CategoryIntro.astro';
import ReportCard from '../../../components/ReportCard.astro';
import { getUsScamTypes, SCAM_CATEGORY_LABELS } from '../../../data/us-scams';

export function getStaticPaths() {
  return getUsScamTypes().map((scam) => ({
    params: { slug: scam.slug },
    props: { scam },
  }));
}

const { scam } = Astro.props;
---

<Layout
  base="/us"
  title={scam.name}
  description={`How to report ${scam.name} in the USA. ${scam.intro.slice(0, 120)}...`}
>
  <p class="back"><a href="/us/">← Back to US overview</a></p>
  <p class="category-label">Category: {SCAM_CATEGORY_LABELS[scam.category]}</p>
  <h1>{scam.name}</h1>

  <section class="story-section" aria-labelledby="story-heading">
    <h2 id="story-heading">How it often plays out</h2>
    <p class="story">{scam.story}</p>
  </section>

  <CategoryIntro intro={scam.intro} steps={scam.steps} />

  <h2>Where to report</h2>

  {scam.reports.map((r) => (
    <ReportCard
      who={r.who}
      when={r.when}
      prepare={r.prepare}
      href={r.href}
      label={r.label}
    />
  ))}
</Layout>

<style>
  .back {
    margin-bottom: var(--space-md);
  }

  .back a {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .back a:hover {
    color: var(--color-accent);
  }

  .category-label {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .story-section {
    margin: var(--space-xl) 0;
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: 0 var(--radius) var(--radius) 0;
  }

  .story-section h2 {
    margin-top: 0;
    font-size: 1.1rem;
    color: var(--color-text-muted);
  }

  .story {
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
  }
</style>
