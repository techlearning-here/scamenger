---
import Layout from '../../../layouts/Layout.astro';
import CategoryIntro from '../../../components/CategoryIntro.astro';
import ReportCard from '../../../components/ReportCard.astro';
import { getUsScamBySlug, getUsScamTypes, SCAM_CATEGORY_LABELS } from '../../../data/us-scams';

export function getStaticPaths() {
  return getUsScamTypes().map((scam) => ({
    params: { slug: scam.slug },
    props: { scam },
  }));
}

const { scam } = Astro.props;
const siteOrigin = Astro.site ? new URL(Astro.site).origin : '';
const canonicalUrl = siteOrigin ? `${siteOrigin}/us/scams/${scam.slug}/` : undefined;
const metaDesc = scam.intro.length > 155 ? scam.intro.slice(0, 152).trim() + '...' : scam.intro;
const categoryLabel = SCAM_CATEGORY_LABELS[scam.category];
const pageKeywords = `report ${scam.name}, ${scam.name} fraud, where to report ${scam.name}, report fraud USA, FTC report, IC3, ${categoryLabel}`;
const relatedScams = (scam.relatedSlugs ?? [])
  .map((slug) => getUsScamBySlug(slug))
  .filter((s): s is NonNullable<typeof s> => s != null);
---

<Layout
  title={scam.name}
  description={`How to report ${scam.name} in the USA. ${metaDesc}`}
  keywords={pageKeywords}
  canonical={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: `How to report ${scam.name} in the USA`,
    description: metaDesc,
    url: canonicalUrl,
    publisher: { '@type': 'Organization', name: 'Scam Avenger' },
  })} />
  <p class="back"><a href="/">← Back to Home</a></p>
  <p class="category-label">Category: {SCAM_CATEGORY_LABELS[scam.category]}</p>
  <h1>{scam.name}</h1>

  {scam.warning ? (
    <section class="warning-section" aria-labelledby="warning-heading">
      <h2 id="warning-heading" class="visually-hidden">Important</h2>
      <p class="warning-text">{scam.warning}</p>
    </section>
  ) : null}

  <section class="story-section" aria-labelledby="story-heading">
    <h2 id="story-heading">How it often plays out</h2>
    <p class="story">{scam.story}</p>
  </section>

  {(scam.statistics?.length ?? 0) > 0 ? (
    <section class="statistics-section" aria-labelledby="statistics-heading">
      <h2 id="statistics-heading">By the numbers</h2>
      <ul>
        {scam.statistics!.map((stat) => (
          <li>{stat}</li>
        ))}
      </ul>
    </section>
  ) : null}

  {(scam.spotIt?.length ?? 0) > 0 ? (
    <section class="spot-section" aria-labelledby="spot-heading">
      <h2 id="spot-heading">How to spot it</h2>
      <ul>
        {scam.spotIt!.map((tip) => (
          <li>{tip}</li>
        ))}
      </ul>
    </section>
  ) : (
    <section class="spot-section" aria-labelledby="spot-heading">
      <h2 id="spot-heading">How to spot it</h2>
      <p class="spot-generic">Common red flags: pressure to act immediately, requests for payment by gift card or wire, offers that seem too good to be true, or unsolicited requests for your personal or financial details.</p>
    </section>
  )}

  {(scam.dos?.length ?? 0) > 0 || (scam.donts?.length ?? 0) > 0 ? (
    <section class="dos-donts" aria-labelledby="dos-donts-heading">
      <h2 id="dos-donts-heading">Do's and don'ts</h2>
      <div class="dos-donts-grid">
        {(scam.dos?.length ?? 0) > 0 ? (
          <div class="dos-list">
            <h3>Do</h3>
            <ul>
              {scam.dos!.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ) : null}
        {(scam.donts?.length ?? 0) > 0 ? (
          <div class="donts-list">
            <h3>Don't</h3>
            <ul>
              {scam.donts!.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ) : null}
      </div>
    </section>
  ) : null}

  <CategoryIntro intro={scam.intro} steps={scam.steps} />

  <h2>Where to report</h2>

  {scam.reports.map((r) => (
    <ReportCard
      who={r.who}
      when={r.when}
      prepare={r.prepare}
      href={r.href}
      label={r.label}
    />
  ))}

  {relatedScams.length > 0 ? (
    <section class="related-section" aria-labelledby="related-heading">
      <h2 id="related-heading">Related scams</h2>
      <ul class="related-list">
        {relatedScams.map((related) => (
          <li><a href={`/us/scams/${related.slug}/`}>{related.name}</a></li>
        ))}
      </ul>
    </section>
  ) : null}

  {(scam.faq?.length ?? 0) > 0 ? (
    <section class="faq-section" aria-labelledby="faq-heading">
      <h2 id="faq-heading">Frequently asked questions</h2>
      <dl class="faq-list">
        {scam.faq!.map((item) => (
          <>
            <dt>{item.question}</dt>
            <dd>{item.answer}</dd>
          </>
        ))}
      </dl>
    </section>
  ) : null}

  {(scam.learnMore?.length ?? 0) > 0 ? (
    <section class="learn-more-section" aria-labelledby="learn-more-heading">
      <h2 id="learn-more-heading">Learn more</h2>
      <ul class="learn-more-list">
        {scam.learnMore!.map((link) => (
          <li><a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a></li>
        ))}
      </ul>
    </section>
  ) : null}
</Layout>

<style>
  .back {
    margin-bottom: var(--space-md);
  }

  .back a {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .back a:hover {
    color: var(--color-accent);
  }

  .category-label {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .story-section {
    margin: var(--space-xl) 0;
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: 0 var(--radius) var(--radius) 0;
  }

  .story-section h2 {
    margin-top: 0;
    font-size: 1.1rem;
    color: var(--color-text-muted);
  }

  .story {
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
  }

  .spot-section {
    margin: var(--space-xl) 0;
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: 0 var(--radius) var(--radius) 0;
  }

  .spot-section h2 {
    margin-top: 0;
    margin-bottom: var(--space-md);
    font-size: 1.1rem;
    color: var(--color-text-muted);
  }

  .spot-section ul {
    margin: 0;
    padding-left: 1.25rem;
  }

  .spot-section li {
    margin-bottom: var(--space-sm);
    line-height: 1.5;
  }

  .spot-section .spot-generic {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text);
  }

  .dos-donts {
    margin: var(--space-xl) 0;
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: 0 var(--radius) var(--radius) 0;
  }

  .dos-donts h2 {
    margin-top: 0;
    margin-bottom: var(--space-md);
    font-size: 1.1rem;
    color: var(--color-text-muted);
  }

  .dos-donts-grid {
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: 1fr 1fr;
  }

  @media (max-width: 640px) {
    .dos-donts-grid {
      grid-template-columns: 1fr;
    }
  }

  .dos-list h3,
  .donts-list h3 {
    font-size: 1rem;
    margin: 0 0 var(--space-sm);
    color: var(--color-text);
  }

  .dos-list h3 {
    color: var(--color-accent);
  }

  .donts-list h3 {
    color: var(--color-error, #c00);
  }

  .dos-list ul,
  .donts-list ul {
    margin: 0;
    padding-left: 1.25rem;
  }

  .dos-list li,
  .donts-list li {
    margin-bottom: var(--space-sm);
    line-height: 1.5;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .warning-section {
    margin: var(--space-lg) 0;
    padding: var(--space-lg);
    background: var(--color-error-bg, #fef2f2);
    border: 1px solid var(--color-error-border, #fecaca);
    border-left: 4px solid var(--color-error, #c00);
    border-radius: 0 var(--radius) var(--radius) 0;
  }

  .warning-text {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.5;
    color: var(--color-error-text, #991b1b);
  }

  .statistics-section {
    margin: var(--space-xl) 0;
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: 0 var(--radius) var(--radius) 0;
  }

  .statistics-section h2 {
    margin-top: 0;
    margin-bottom: var(--space-md);
    font-size: 1.1rem;
    color: var(--color-text-muted);
  }

  .statistics-section ul {
    margin: 0;
    padding-left: 1.25rem;
  }

  .statistics-section li {
    margin-bottom: var(--space-sm);
    line-height: 1.5;
  }

  .related-section {
    margin: var(--space-xl) 0;
  }

  .related-section h2 {
    font-size: 1.1rem;
    margin-bottom: var(--space-md);
    color: var(--color-text-muted);
  }

  .related-list {
    margin: 0;
    padding-left: 1.25rem;
  }

  .related-list li {
    margin-bottom: var(--space-sm);
    line-height: 1.5;
  }

  .related-list a:hover {
    color: var(--color-accent);
  }

  .faq-section {
    margin: var(--space-xl) 0;
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: 0 var(--radius) var(--radius) 0;
  }

  .faq-section h2 {
    margin-top: 0;
    margin-bottom: var(--space-md);
    font-size: 1.1rem;
    color: var(--color-text-muted);
  }

  .faq-list {
    margin: 0;
  }

  .faq-list dt {
    font-weight: 600;
    margin-top: var(--space-md);
    margin-bottom: var(--space-xs);
  }

  .faq-list dt:first-of-type {
    margin-top: 0;
  }

  .faq-list dd {
    margin: 0 0 0 1rem;
    line-height: 1.6;
  }

  .learn-more-section {
    margin: var(--space-xl) 0;
  }

  .learn-more-section h2 {
    font-size: 1.1rem;
    margin-bottom: var(--space-md);
    color: var(--color-text-muted);
  }

  .learn-more-list {
    margin: 0;
    padding-left: 1.25rem;
  }

  .learn-more-list li {
    margin-bottom: var(--space-sm);
    line-height: 1.5;
  }

  .learn-more-list a:hover {
    color: var(--color-accent);
  }
</style>
